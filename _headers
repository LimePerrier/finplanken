# Cloudflare Pages headers file (https://developers.cloudflare.com/pages/configuration/headers/)
# Applied automatically when this folder is the deploy output.

# Sensible security headers for a static brochure site
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Asset caching. styles.css and nav.js are edited in place under stable
# filenames, so a long cache serves stale code until it expires - which is
# what shipped the bio layout against a day-old stylesheet.
#
# These rules are ordered so the outcome is safe whichever way Cloudflare
# resolves an overlap: if the first match wins, CSS and JS revalidate every
# time; if the last match wins, everything under /assets is at most five
# minutes stale. Neither outcome can reproduce the 24 hour failure.
/assets/styles.css
  Cache-Control: no-cache

/assets/nav.js
  Cache-Control: no-cache

# HTML stays uncached so content edits go live immediately.
/assets/*
  Cache-Control: public, max-age=300, must-revalidate
